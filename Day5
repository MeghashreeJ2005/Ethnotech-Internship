    result=num1+num2
    print(f"{num1}+{num2}={result}")
  elif operation=="-":
    result=num1-num2
    print(f"{num1}-{num2}={result}")
  elif operation=="*":
    result=num1*num2
    print(f"{num1}*{num2}={result}")
  elif operation=="/":
   if num2!=0:
